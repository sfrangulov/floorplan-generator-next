      "children": "#F2C6D0",
      "cabinet": "#C4D8E8",
      "kitchen": "#F5C882",
      "kitchen_dining": "#F5D09A",
      "kitchen_niche": "#F5D09A",
      "hallway": "#D1D1CE",
      "corridor": "#D1D1CE",
