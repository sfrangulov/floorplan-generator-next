{
  "name": "blueprint",
  "canvas": {
    "width": 2000,
    "height": 2000,
    "background": "#FFFFFF"
  },
  "walls": {
    "outer_stroke": "#000000",
    "outer_width": 4.0,
    "inner_stroke": "#000000",
    "inner_width": 1.5
  },
  "rooms": {
    "default_fill": "none",
    "default_stroke": "#000000",
    "stroke_width": 0.5,
    "fills": {}
  },
  "doors": {
    "stroke": "#000000",
    "stroke_width": 1.0,
    "arc_stroke": "#000000",
    "arc_width": 0.5,
    "gap_fill": "#FFFFFF"
  },
  "windows": {
    "stroke": "#000000",
    "stroke_width": 1.0,
    "fill": "#FFFFFF",
    "cross_stroke": "#000000"
  },
  "furniture": {
    "stroke": "#000000",
    "stroke_width": 0.8,
    "fill": "none"
  },
  "riser": {
    "stroke": "#000000",
    "fill": "#000000",
    "radius": 3.0
  },
  "text": {
    "font_family": "Arial, sans-serif",
    "font_size": 14,
    "fill": "#333333",
    "area_font_size": 11
  }
}
